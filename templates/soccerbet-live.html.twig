{#
/**
 * @file
 * Live-Rangliste – Hülle. Scoreboard und Ranking werden als Sub-Templates
 * gerendert, damit der AJAX-Endpunkt dieselben Templates verwenden kann.
 */
#}
<div class="soccerbet-live" id="soccerbet-live-root"
     data-tournament-id="{{ tournament_id }}"
     data-refresh-url="{{ path('soccerbet.live.json', {tournament_id: tournament_id}) }}">

  <div class="soccerbet-live__header">
    <h2 class="soccerbet-live__title">
      {% if is_live %}<span class="soccerbet-live__dot" aria-label="{{ 'Live'|t }}"></span>{% endif %}
      {{ 'Live standings'|t }}{% if tournament %} – {{ tournament.tournament_desc }}{% endif %}
    </h2>
    <button class="soccerbet-live__refresh button button--small" type="button">
      ↻ {{ 'Refresh'|t }}
    </button>
  </div>

  <div id="soccerbet-live-games">{{ scoreboard }}</div>

  <div id="soccerbet-live-ranking">{{ ranking_content }}</div>

  <div class="soccerbet-live__updated" id="soccerbet-live-updated"></div>

</div>
