{#
/**
 * @file
 * Detail-Ansicht der Tipps und Punkte eines einzelnen Tippers.
 *
 * Variablen:
 * - tipper: Array mit name, basispunkte, bonuspunkte, sonderpunkte,
 *           totalpergame, tipp, game_desc, game_flags, game_score,
 *           ergebnisse, tendenzen, total, tipper_has_paid
 * - tournament: Turnier-Objekt
 * - avatar_url: string|null
 * - stars: int
 */
#}
{% import '@soccerbet/soccerbet-flag.html.twig' as flag_helper %}
<div class="soccerbet-tipper-detail">

  <div class="soccerbet-tipper-detail__back">
    <a href="{{ path('soccerbet.standings', {tournament_id: tournament.tournament_id}) }}">
      ← {{ 'Back to standings'|t }}
    </a>
  </div>

  <div class="soccerbet-tipper-detail__header">
    <span class="soccerbet-avatar soccerbet-avatar--lg">
      {% if avatar_url %}
        <img src="{{ avatar_url }}" alt="{{ tipper.name }}" loading="lazy">
      {% endif %}
    </span>
    <div class="soccerbet-tipper-detail__name-wrap">
      <div class="soccerbet-tipper-detail__name-row">
        <h2 class="soccerbet-tipper-detail__name">{{ tipper.name }}</h2>
        {% if not tipper.tipper_has_paid %}
          <span class="soccerbet-badge soccerbet-badge--unpaid">{{ 'Stake pending'|t }}</span>
        {% endif %}
      </div>
      {% if stars > 0 %}
        <span class="soccerbet-stars" title="{{ stars ~ ' × Tournament winner'|t }}">
          {% for i in 1..stars %}★{% endfor %}
        </span>
      {% endif %}
    </div>
  </div>

  <div class="soccerbet-tipper-detail__summary">
    <span class="summary-item">
      <strong>{{ tipper.total }}</strong> {{ 'Total points'|t }}
    </span>
    <span class="summary-separator">·</span>
    <span class="summary-item">
      {{ tipper.ergebnisse }} {{ 'correct results'|t }}
    </span>
    <span class="summary-separator">·</span>
    <span class="summary-item">
      {{ tipper.tendenzen }} {{ 'correct tendencies'|t }}
    </span>
  </div>

  {% if tipper.game_desc is not empty %}
    <table class="soccerbet-tipper-detail__table">
      <thead>
        <tr>
          <th class="col-game">{{ 'Match'|t }}</th>
          <th class="col-result">{{ 'Result'|t }}</th>
          <th class="col-tipp">{{ 'Your bet'|t }}</th>
          <th class="col-base" title="{{ 'Base points: 3 = correct result, 1 = correct tendency'|t }}">{{ 'Base'|t }}</th>
          <th class="col-bonus" title="{{ 'Bonus points: +1 per tendency bettor, +2 per wrong bettor (on correct result); +1 per wrong bettor (on correct tendency)'|t }}">{{ 'Bonus'|t }}</th>
          <th class="col-special" title="{{ 'Special points: correct qualifier in KO round = number of participants'|t }}">{{ 'Special'|t }}</th>
          <th class="col-total">{{ 'Total'|t }}</th>
        </tr>
      </thead>
      <tbody>
        {% for game_id, game_desc in tipper.game_desc %}
          {% set base    = tipper.basispunkte[game_id]  ?? 0 %}
          {% set bonus   = tipper.bonuspunkte[game_id]  ?? 0 %}
          {% set special = tipper.sonderpunkte[game_id] ?? 0 %}
          {% set total   = tipper.totalpergame[game_id] ?? 0 %}
          {% set tipp    = tipper.tipp[game_id]         ?? 'N.A.' %}
          {% set score   = tipper.game_score[game_id]   ?? '—' %}
          {% set flags   = tipper.game_flags[game_id]   ?? {} %}

          <tr class="
            {% if base == 3 %}row--exact
            {% elseif base == 1 %}row--tendency
            {% elseif tipp == 'N.A.' %}row--no-tipp
            {% else %}row--wrong{% endif %}">
            <td class="col-game">
              <span class="soccerbet-game-matchup">
                <span class="soccerbet-game-matchup__team">
                  {{ flag_helper.flag(flags.team1_flag ?? '', flags.team1_name|t, 20, soccerbet_module_path) }}
                  <span>{{ flags.team1_name|t }}</span>
                </span>
                <span class="soccerbet-game-matchup__team">
                  {{ flag_helper.flag(flags.team2_flag ?? '', flags.team2_name|t, 20, soccerbet_module_path) }}
                  <span>{{ flags.team2_name|t }}</span>
                </span>
              </span>
            </td>
            <td class="col-result">{{ score }}</td>
            <td class="col-tipp">
              {% if tipp == 'N.A.' %}
                <span class="tipp--missing">{{ 'no bet'|t }}</span>
              {% else %}
                {{ tipp }}
              {% endif %}
            </td>
            <td class="col-base">{{ base }}</td>
            <td class="col-bonus">{{ bonus > 0 ? '+' ~ bonus : '—' }}</td>
            <td class="col-special">{{ special > 0 ? '+' ~ special : '—' }}</td>
            <td class="col-total"><strong>{{ total }}</strong></td>
          </tr>
        {% endfor %}
      </tbody>
      <tfoot>
        <tr class="row--total">
          <td class="col-game"><strong>{{ 'Total'|t }}</strong></td>
          <td class="col-result">{{ tipper.ergebnisse }}</td>
          <td class="col-tipp">{{ tipper.tendenzen }}</td>
          <td class="col-base">{{ tipper.ergebnisse ~ '×3' }}</td>
          <td class="col-bonus"></td>
          <td class="col-special"></td>
          <td class="col-total"><strong>{{ tipper.total }}</strong></td>
        </tr>
      </tfoot>
    </table>
  {% else %}
    <p class="soccerbet-tipper-detail__empty">
      {{ 'No matches played yet.'|t }}
    </p>
  {% endif %}


</div>
