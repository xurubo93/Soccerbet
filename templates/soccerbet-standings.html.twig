{#
/**
 * @file
 * Rangliste eines Turniers.
 *
 * Variablen:
 * - rows: Array mit Tipper-Einträgen (rank, name, paid, ergebnisse, tendenzen, total, diff)
 * - tournament: Turnier-Objekt
 * - played_games: Anzahl bereits gespielter Spiele
 */
#}
<div class="soccerbet-standings">

  <h2 class="soccerbet-standings__title">
    {{ 'Standings'|t }}
    {% if tournament %}
      – {{ tournament.tournament_desc }}
    {% endif %}
  </h2>

  {# Tab-Navigation #}
  <nav class="soccerbet-standings__tabs" aria-label="{{ 'Select view'|t }}">
    <a href="#tab-rangliste" class="soccerbet-standings__tab soccerbet-standings__tab--active" data-tab="rangliste">
      {{ 'Standings'|t }}
    </a>
    <a href="#tab-bonus" class="soccerbet-standings__tab" data-tab="bonus">
      {{ 'Bonus'|t }}
      {% if winner_bets is not empty %}
        <span class="soccerbet-standings__tab-badge">{{ winner_bets|length }}</span>
      {% endif %}
    </a>
  </nav>

  {# Rangliste-Tab #}
  <div id="tab-rangliste" class="soccerbet-standings__tab-content">

  {% if played_games == 0 %}
    <p class="soccerbet-standings__empty">
      {{ 'No matches played yet or no bets placed.'|t }}
    </p>
  {% elseif rows is empty %}
    <p class="soccerbet-standings__empty">
      {{ 'No participants in this tournament.'|t }}
    </p>
  {% else %}

    {# Steps-Navigation – sticky, über der Tabelle #}
    {% if step_mode %}
      <nav class="soccerbet-steps" aria-label="{{ 'Select round'|t }}">
        {% if step_limit > 1 %}
          <a href="{{ path('soccerbet.standings_step', {tournament_id: tournament.tournament_id, limit: step_limit - 1}) }}"
             class="soccerbet-steps__btn">← {{ 'Previous round'|t }}</a>
        {% endif %}
        <span class="soccerbet-steps__info">
          {{ 'Round @current of @max'|t({'@current': step_limit, '@max': max_games}) }}
        </span>
        {% if step_limit < max_games %}
          <a href="{{ path('soccerbet.standings_step', {tournament_id: tournament.tournament_id, limit: step_limit + 1}) }}"
             class="soccerbet-steps__btn">{{ 'Next round'|t }} →</a>
        {% endif %}
      </nav>
    {% endif %}

    <div class="soccerbet-standings__links">
      {% if not step_mode and played_games > 1 %}
        <a href="{{ path('soccerbet.standings_step', {tournament_id: tournament.tournament_id, limit: 1}) }}"
           class="soccerbet-steps__btn">
          {{ 'Browse rounds'|t }}
        </a>
      {% endif %}
      <a href="{{ path('soccerbet.tipps.overview', {tournament_id: tournament.tournament_id}) }}"
         class="soccerbet-steps__btn">
        {{ 'All bets'|t }}
      </a>
    </div>

    <table class="soccerbet-standings__table">
      <thead>
        <tr>
          <th class="col-rank">{{ 'Rank'|t }}</th>
          <th class="col-name">{{ 'Name'|t }}</th>
          <th class="col-exact">{{ 'Correct results'|t }}</th>
          <th class="col-tend">{{ 'Correct tendencies'|t }}</th>
          <th class="col-total">{{ 'Points'|t }}</th>
        </tr>
      </thead>
      <tbody>
        {% for row in rows %}
          <tr class="soccerbet-standings__row
            {% if row.diff > 0 %} row--up
            {% elseif row.diff < 0 %} row--down
            {% else %} row--equal{% endif %}">

            <td class="col-rank">
              {{ row.rank }}
              {% if row.diff != 0 and row.rank_before != 0 %}
                <span class="rank-diff rank-diff--{{ row.diff > 0 ? 'up' : 'down' }}">
                  ({{ row.diff > 0 ? '+' : '' }}{{ row.diff }})
                </span>
              {% endif %}
            </td>

            <td class="col-name">
              <a class="soccerbet-tipper-card" href="{{ path('soccerbet.standings_tipper', {tournament_id: tournament.tournament_id, tipper_id: row.tipper_id}) }}">
                <span class="soccerbet-avatar">
                  {% if row.avatar_url %}
                    <img src="{{ row.avatar_url }}" alt="{{ row.name }}" loading="lazy">
                  {% endif %}
                </span>
                <span class="soccerbet-tipper-card__name">
                  <span class="soccerbet-tipper-card__label">{{ row.name }}</span>
                  {% if row.stars > 0 %}
                    <span class="soccerbet-stars" title="{{ row.stars ~ ' × Tournament winner'|t }}">
                      {% for i in 1..row.stars %}★{% endfor %}
                    </span>
                  {% endif %}
                </span>
              </a>
              {% if not row.paid %}
                <span class="soccerbet-badge soccerbet-badge--unpaid">
                  {{ 'Stake pending'|t }}
                </span>
              {% endif %}
            </td>

            <td class="col-exact">{{ row.ergebnisse }}</td>
            <td class="col-tend">{{ row.tendenzen }}</td>
            <td class="col-total"><strong>{{ row.total }}</strong></td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

  {% endif %}

  </div>{# end tab-rangliste #}

  {# Bonus-Tab #}
  <div id="tab-bonus" class="soccerbet-standings__tab-content" hidden>
    <table class="soccerbet-standings__table soccerbet-bonus__table">
      <thead>
        <tr>
          <th class="col-name">{{ 'Bettor'|t }}</th>
          <th class="col-bonus-team">{{ 'Tournament winner bet'|t }}</th>
          <th class="col-bonus-pts">{{ 'Possible points'|t }}</th>
          <th class="col-bonus-result">{{ 'Result'|t }}</th>
        </tr>
      </thead>
      <tbody>
        {% for bet in winner_bets %}
          <tr class="soccerbet-bonus__row{% if bet.is_correct %} soccerbet-bonus__row--correct{% elseif bet.actual_points is not null %} soccerbet-bonus__row--wrong{% endif %}">
            <td class="col-name">{{ bet.tipper_name }}</td>
            <td class="col-bonus-team">{{ bet.team_name|t }}</td>
            <td class="col-bonus-pts"><strong>{{ bet.possible_points }}</strong></td>
            <td class="col-bonus-result">
              {% if bet.actual_points is not null %}
                {% if bet.is_correct %}
                  <span class="soccerbet-bonus__correct">✓ +{{ bet.actual_points }}</span>
                {% else %}
                  <span class="soccerbet-bonus__wrong">✗ 0</span>
                {% endif %}
              {% else %}
                <span class="soccerbet-text-muted">—</span>
              {% endif %}
            </td>
          </tr>
        {% else %}
          <tr><td colspan="4">{{ 'No tournament winner bets placed yet.'|t }}</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>{# end tab-bonus #}

  {% if past_tournaments is not empty %}
    <div class="soccerbet-standings__past">
      <h3 class="soccerbet-standings__past-title">{{ 'Past tournaments'|t }}</h3>
      <table class="soccerbet-standings__past-table">
        <thead>
          <tr>
            <th>{{ 'Tournament'|t }}</th>
            <th>{{ 'Top 3'|t }}</th>
          </tr>
        </thead>
        <tbody>
          {% for t in past_tournaments %}
            <tr>
              <td><a href="{{ t.url }}">{{ t.tournament_desc }}</a></td>
              <td>
                {% for row in t.top3 %}
                  <span class="soccerbet-standings__past-place soccerbet-standings__past-place--{{ loop.index }}">
                    {{- row.rank }}. {{ row.name -}}
                  </span>
                {% else %}
                  <span class="soccerbet-standings__past-empty">—</span>
                {% endfor %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}

</div>
