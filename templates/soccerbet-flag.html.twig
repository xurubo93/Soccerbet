{#
/**
 * @file
 * Hilfsmakro für die Flaggen-Darstellung.
 *
 * Verwendung in anderen Templates:
 *   {% import 'modules/custom/soccerbet/templates/soccerbet-flag.html.twig' as flag_helper %}
 *   {{ flag_helper.flag('AT', 'Österreich') }}
 *   {{ flag_helper.flag('GB-ENG', 'England') }}
 *
 * Das Makro versucht zuerst SVG, fällt via onerror auf PNG@2x zurück.
 * Basis-Pfad: /modules/custom/soccerbet/images/flags/
 *   SVG:  svg/{code_lower}.svg
 *   PNG:  PNG/2x/{code_upper}@2x.png
 *   PNG1: PNG/1x/{code_upper}.png  (Fallback für Sondercodes wie GB-ENG)
 */
#}

{% macro flag(code, alt, width, height) %}
  {% if code %}
    {% set w = width|default(28) %}
    {% set h = height|default(19) %}
    {% set code_upper = code|upper %}
    {% set code_lower = code|lower %}
    {% set base = '/modules/custom/soccerbet/images/flags' %}
    {% set svg_src = base ~ '/svg/' ~ code_lower ~ '.svg' %}
    {% set png2x   = base ~ '/PNG/2x/' ~ code_upper ~ '@2x.png' %}
    {% set png1x   = base ~ '/PNG/1x/' ~ code_upper ~ '.png' %}
    <img
      src="{{ svg_src }}"
      onerror="this.onerror=null;this.src='{{ png2x }}';this.onerror=function(){this.src='{{ png1x }}'}"
      alt="{{ alt|default(code_upper)|escape }}"
      width="{{ w }}"
      height="{{ h }}"
      class="soccerbet-flag"
      loading="lazy"
    >
  {% endif %}
{% endmacro %}
