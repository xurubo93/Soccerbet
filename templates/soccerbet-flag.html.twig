{#
/**
 * @file
 * Hilfsmakro für die Flaggen-Darstellung (circle-flags, kapowaz/circle-flags).
 *
 * Verwendung in anderen Templates:
 *   {% import 'modules/custom/soccerbet/templates/soccerbet-flag.html.twig' as flag_helper %}
 *   {{ flag_helper.flag('AT', 'Österreich') }}
 *   {{ flag_helper.flag('GB-ENG', 'England') }}
 *
 * Alle Flags sind SVG-Kreise (512×512), Dateiname = lowercase ISO-Code.
 * Basis-Pfad: /modules/custom/soccerbet/images/flags/svg/{code_lower}.svg
 */
#}

{% macro flag(code, alt, width, height) %}
  {% if code %}
    {% set size = width|default(24) %}
    {% set code_lower = code|lower %}
    {% set src = '/modules/custom/soccerbet/images/flags/svg/' ~ code_lower ~ '.svg' %}
    <img
      src="{{ src }}"
      alt="{{ alt|default(code|upper)|escape }}"
      width="{{ size }}"
      height="{{ size }}"
      class="soccerbet-flag"
      loading="lazy"
    >
  {% endif %}
{% endmacro %}
